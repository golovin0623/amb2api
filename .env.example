# ============================================================================
# amb2api 环境变量示例 —— 复制为 .env 后按需修改： cp .env.example .env
# 所有键也可在管理面板 /ui 中修改（除非 CONFIG_OVERRIDE_ENV=true 锁定为环境优先）。
# ============================================================================

# ---- 鉴权（务必修改默认值！）------------------------------------------------
# API 口令：OpenAI 入口用 Authorization: Bearer，Anthropic 入口用 x-api-key
API_PASSWORD=change-me
# 管理面板 /ui 与管理类接口（/api/keys、/api/account、/api/playground）口令
PANEL_PASSWORD=change-me
# 通用口令（若设置，会同时覆盖上面两个）
# PASSWORD=

# ---- AssemblyAI LLM Gateway 上游 -------------------------------------------
USE_ASSEMBLY=true
# 多个 key 用英文逗号分隔，自动轮换 + 限流追踪
ASSEMBLY_API_KEYS=your_assembly_key_1,your_assembly_key_2
# 网关端点（一般无需修改）
# ASSEMBLY_ENDPOINT=https://llm-gateway.assemblyai.com/v1/chat/completions

# ---- 服务器 ----------------------------------------------------------------
HOST=0.0.0.0
PORT=7861

# ---- 存储后端（按 Redis > Postgres > MongoDB > 本地文件 顺序自动选择）-------
# 设置任意一个即启用对应后端；都不设则用本地 ./creds 文件存储。
# REDIS_URI=redis://:password@localhost:6379/0
# REDIS_PREFIX=AMB2API
# POSTGRES_DSN=postgresql://user:password@localhost:5432/amb2api
# MONGODB_URI=mongodb://user:password@localhost:27017/amb2api

# ---- 配置优先级 ------------------------------------------------------------
# true：环境变量锁定优先；false：面板可覆盖（默认行为见 config.py）
CONFIG_OVERRIDE_ENV=true
# 配置快照缓存 TTL（秒），0 关闭。降低热路径的存储读放大。
# CONFIG_CACHE_TTL=3

# ---- 重试 / 限流 -----------------------------------------------------------
# RETRY_429_ENABLED=true
# RETRY_429_MAX_RETRIES=5
# RETRY_429_INTERVAL=1
# CALLS_PER_ROTATION=100

# ---- 自动封禁 --------------------------------------------------------------
# AUTO_BAN=false
# AUTO_BAN_ERROR_CODES=401,403

# ---- 流式 ------------------------------------------------------------------
# 真实流式（默认开）；个别上游异常时可临时设为 false 走假流式兜底
# ENABLE_REAL_STREAMING=true
# 每 N 秒发送 SSE keepalive 注释帧（0 关闭）
# STREAM_KEEPALIVE_SECONDS=0

# ---- Prompt Caching --------------------------------------------------------
# PROMPT_CACHE_ENABLED=true
# PROMPT_CACHE_AFFINITY_ENABLED=true
# PROMPT_CACHE_AUTO_MODE=conservative
# PROMPT_CACHE_DEFAULT_TTL=5m

# ---- CORS（默认 * 且不带凭证；如需带凭证请填显式来源白名单）-----------------
# CORS_ALLOW_ORIGINS=https://panel.example.com,https://app.example.com

# ---- 日志 ------------------------------------------------------------------
LOG_LEVEL=info
LOG_FILE=log.txt
# 日志按大小轮转（字节），与保留份数
# LOG_MAX_BYTES=10485760
# LOG_BACKUP_COUNT=3

# ---- 其他 ------------------------------------------------------------------
# HTTP 代理（如需）
# PROXY=http://127.0.0.1:7890
